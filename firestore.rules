rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public catalog data read by the website (no login on the client).
    // Writes are locked to the client SDK: admins write via the Firebase
    // Console or the Admin SDK, both of which bypass these rules entirely.
    // If an authenticated admin UI is added later, `request.auth != null`
    // will let signed-in users write.
    match /inventory/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /projects/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /careers/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Everything else: deny by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
